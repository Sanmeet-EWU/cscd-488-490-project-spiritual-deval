@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using SpiritualDevalApp.Data
@using SpiritualDevalApp.Models.Entities
@using System.Security.Policy
@inject AppDbContext DbContext
@attribute [Authorize(Roles = "Administrator")]

@code {
    private IEnumerable<Event>? UpcomingEvents;
    private IEnumerable<Event>? PastEvents;
    private Dictionary<int, List<UserAccount>> RegisteredUsersByEvent = new();

    protected override async Task OnInitializedAsync()
    {
        var currentDate = DateTime.Now;
        UpcomingEvents = await DbContext.Events
            .Where(e => e.EventDate >= currentDate)
            .OrderBy(e => e.EventDate)
            .ToListAsync();

        PastEvents = await DbContext.Events
            .Where(e => e.EventDate < currentDate)
            .OrderByDescending(e => e.EventDate)
            .ToListAsync();

        await LoadRegisteredUsers();
    }

    private async Task LoadRegisteredUsers()
    {
        var registrations = await DbContext.EventRegistrations
            .Include(er => er.User)
            .ToListAsync();

        RegisteredUsersByEvent = registrations
            .GroupBy(er => er.EventId)
            .ToDictionary(g => g.Key, g => g.Select(er => er.User).ToList());
    }
}

<h1 class="header-text">Admin Dashboard</h1>
<p class="intro-text">Welcome, Administrator! Manage events and view registered users.</p>

<div class="admin-section">
    <h2>Upcoming Events</h2>
    @if (UpcomingEvents != null && UpcomingEvents.Any())
    {
        <ul class="event-list">
            @foreach (var eventItem in UpcomingEvents)
            {
                <li>
                    <details>
                        <summary>@eventItem.EventTitle</summary>
                        @if (RegisteredUsersByEvent.TryGetValue(eventItem.EventId, out var users) && users.Any())
                        {
                            <table class="event-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Username</th>
                                        <th>Email</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in users)
                                    {
                                        <tr>
                                            <td>@user.FirstName @user.LastName</td>
                                            <td>@user.UserName</td>
                                            <td>@user.Email</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p>No users registered for this event.</p>
                        }
                    </details>
                </li>
            }
        </ul>
    }
    else
    {
        <p>No upcoming events.</p>
    }
</div>

<div class="admin-section">
    <h2>Past Events</h2>
    @if (PastEvents != null && PastEvents.Any())
    {
        <ul class="event-list">
            @foreach (var eventItem in PastEvents)
            {
                <li>
                    <details>
                        <summary>@eventItem.EventTitle</summary>
                        @if (RegisteredUsersByEvent.TryGetValue(eventItem.EventId, out var users) && users.Any())
                        {
                            <table class="event-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Username</th>
                                        <th>Email</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in users)
                                    {
                                        <tr>
                                            <td>@user.FirstName @user.LastName</td>
                                            <td>@user.UserName</td>
                                            <td>@user.Email</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p>No users registered for this event.</p>
                        }
                    </details>
                </li>
            }
        </ul>
    }
    else
    {
        <p>No past events.</p>
    }
</div>

<style>
    .header-text {
        text-align: center;
        font-size: 2em;
        color: #556b2f;
        font-family: 'Georgia', serif;
        margin: 50px 0 20px;
    }

    .intro-text {
        text-align: center;
        margin: 20px auto;
        max-width: 600px;
    }

    .admin-section {
        margin: 40px auto;
        max-width: 800px;
        padding: 20px;
        background-color: #f4f4f4;
        border-radius: 8px;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    }

    .admin-section h2 {
        font-size: 1.8em;
        color: #4f7c5d;
    }

    .event-list {
        list-style: none;
        padding: 0;
    }

    .event-list details {
        background: white;
        padding: 10px;
        border-radius: 5px;
        box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.1);
        margin-bottom: 10px;
    }

    .event-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

    .event-table th, .event-table td {
        padding: 10px;
        border: 1px solid #ccc;
    }

    .event-table th {
        background-color: #4f7c5d;
        color: white;
    }
</style>
